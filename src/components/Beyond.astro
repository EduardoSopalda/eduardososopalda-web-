---
// The room beyond the threshold — an infinite white void. Where the
// hero is dark bronze and metal, this room is bone-white and bare:
// a single small pig, alone in the frame, speaking the real narration
// (beyond-voice.mp3) over PigVoid-speech.mp4, itself re-timed to match
// the audio's exact length rather than the other way around. Captions
// mirror the narration's real pauses, measured from the recorded audio.
const lines = [
  { text: 'People are afraid of edges.', start: 0, end: 2.62 },
  { text: 'Of the place where the light ends...', start: 3.29, end: 5.44 },
  { text: 'and something else begins.', start: 6.2, end: 7.87 },
  { text: 'So they stay in the center,', start: 8.5, end: 9.96 },
  { text: 'where everything is already known.', start: 10.39, end: 12.32 },
  { text: 'But the edge is not a wall.', start: 12.94, end: 15.09 },
  { text: 'The edge is a question.', start: 15.68, end: 17.2 },
  { text: 'What you call a dark corner...', start: 17.75, end: 19.55 },
  { text: 'is just a room you have not entered yet.', start: 20.02, end: 22.23 },
  { text: 'Step back far enough,', start: 22.71, end: 24.03 },
  { text: 'and you will see it.', start: 24.48, end: 25.41 },
  { text: 'The void was never empty.', start: 26.0, end: 27.73 },
  { text: 'It was space.', start: 28.36, end: 29.25 },
  { text: 'Yours.', start: 29.77, end: 30.42 },
];
---

<section id="beyond" class="beyond">
  <div class="void-stage">
    <video
      class="void-video"
      id="void-video"
      poster="/beyond-poster.jpg"
      muted
      playsinline
      preload="none"
      aria-hidden="true"
    >
      <source src="/PigVoid-speech.mp4" type="video/mp4" />
    </video>

    <div class="void-text" id="void-text" aria-live="polite">
      {lines.map((line) => (
        <p class="void-line" data-start={line.start} data-end={line.end}>{line.text}</p>
      ))}
    </div>

    <audio id="beyond-voice" preload="auto">
      <source src="/beyond-voice.mp3" type="audio/mpeg" />
    </audio>
    <audio id="beyond-ambient" preload="auto" loop>
      <source src="/beyond-ambient.mp3" type="audio/mpeg" />
    </audio>
  </div>
</section>

<style>
  .beyond {
    position: relative;
    height: 100svh;
    background: var(--void-white);
    overflow: hidden;
  }

  .void-stage {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .void-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: var(--void-white);
  }

  .void-text {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 14vh;
    pointer-events: none;
  }

  .void-line {
    position: absolute;
    margin: 0;
    max-width: 34rem;
    padding: 0 1.5rem;
    text-align: center;
    font-family: var(--font-body);
    font-weight: 300;
    font-size: clamp(1.1rem, 2.6vw, 1.7rem);
    color: var(--void-ink);
    letter-spacing: 0.01em;
    opacity: 0;
    transition: opacity 0.5s var(--ease);
  }

  .void-line.is-visible {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .void-line {
      transition: none;
    }
  }
</style>

<script>
  function initVoidRoom() {
    const section = document.getElementById('beyond');
    const video = document.getElementById('void-video') as HTMLVideoElement | null;
    const voice = document.getElementById('beyond-voice') as HTMLAudioElement | null;
    const ambient = document.getElementById('beyond-ambient') as HTMLAudioElement | null;
    const cabaret = document.getElementById('cabaret-audio') as HTMLAudioElement | null;
    const soundToggle = document.getElementById('sound-toggle');
    if (!section || !video || !voice || !ambient) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const captionLines = Array.from(section.querySelectorAll<HTMLElement>('.void-line'));
    const speechSrc = '/PigVoid-speech.mp4';
    const zoomoutSrc = '/PigVoid-zoomout.mp4';
    const ambientVolume = 0.4;

    let currentClip: 'speech' | 'zoomout' = 'speech';
    let started = false;
    let roomActive = false;
    let soundOn = soundToggle?.getAttribute('aria-pressed') === 'true';

    const fadeTokens = new WeakMap<HTMLMediaElement, number>();

    function fade(el: HTMLMediaElement, to: number, ms: number, done?: () => void) {
      const token = (fadeTokens.get(el) ?? 0) + 1;
      fadeTokens.set(el, token);
      const from = el.volume;
      const start = performance.now();
      function step(now: number) {
        if (fadeTokens.get(el) !== token) return; // superseded by a later fade
        const t = Math.min(1, (now - start) / ms);
        el.volume = Math.min(1, Math.max(0, from + (to - from) * t));
        if (t < 1) requestAnimationFrame(step);
        else done?.();
      }
      requestAnimationFrame(step);
    }

    function updateCaptions(time: number) {
      for (const line of captionLines) {
        const s = Number(line.dataset.start);
        const e = Number(line.dataset.end);
        line.classList.toggle('is-visible', time >= s && time < e);
      }
    }

    function clearCaptions() {
      for (const line of captionLines) line.classList.remove('is-visible');
    }

    video.addEventListener('timeupdate', () => {
      if (currentClip === 'speech') updateCaptions(video.currentTime);
    });

    video.addEventListener('ended', () => {
      if (currentClip === 'speech') {
        clearCaptions();
        currentClip = 'zoomout';
        video.src = zoomoutSrc;
        video.load();
        video.play().catch(() => {});
      } else {
        currentClip = 'speech';
        video.src = speechSrc;
        video.load();
        video.play().catch(() => {});
        if (soundOn) {
          voice.currentTime = 0;
          voice.play().catch(() => {});
        }
      }
    });

    function enterRoom() {
      roomActive = true;
      if (cabaret && !cabaret.paused) {
        fade(cabaret, 0, 1200, () => cabaret.pause());
      }
      if (soundOn) {
        ambient.play().catch(() => {});
        fade(ambient, ambientVolume, 1500);
        if (currentClip === 'speech') {
          voice.currentTime = video.currentTime;
          voice.play().catch(() => {});
        }
      }
      if (!started) {
        started = true;
        video.preload = 'auto';
        video.load();
      }
      video.play().catch(() => {});
    }

    function leaveRoom() {
      roomActive = false;
      video.pause();
      voice.pause();
      fade(ambient, 0, 900, () => ambient.pause());
      if (soundOn && cabaret && cabaret.paused) {
        cabaret.play().catch(() => {});
        fade(cabaret, 1, 1200);
      }
    }

    document.addEventListener('eduweb:sound', ((e: CustomEvent<{ on: boolean }>) => {
      soundOn = e.detail.on;
      if (!roomActive) return;
      if (soundOn) {
        ambient.play().catch(() => {});
        fade(ambient, ambientVolume, 1000);
        if (currentClip === 'speech') {
          voice.currentTime = video.currentTime;
          voice.play().catch(() => {});
        }
      } else {
        fade(ambient, 0, 800, () => ambient.pause());
        voice.pause();
      }
    }) as EventListener);

    if (reducedMotion) {
      enterRoom();
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) enterRoom();
          else leaveRoom();
        }
      },
      { threshold: 0.35 },
    );
    observer.observe(section);
  }

  initVoidRoom();
</script>
